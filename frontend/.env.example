# Frontend (Next.js) — copy to .env.local for local dev
# Public vars must be prefixed with NEXT_PUBLIC_

NODE_ENV=development

# Public site URL (SEO, canonical links)
NEXT_PUBLIC_SITE_URL="http://localhost:3100"

# Backend API base URL (no trailing slash)
# Must match backend PORT (default 3101). E2E overrides to 3102 via playwright.config.ts.
NEXT_PUBLIC_API_URL="http://localhost:3101/api/v1"

# Analytics (optional — PostHog or GA4)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Cloudinary image CDN (required in production for lower latency)
# Same cloud name as backend CLOUDINARY_CLOUD_NAME.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Optional: uploaded logo public_id (e.g. bmv/brand/logo). Falls back to
# fetching NEXT_PUBLIC_SITE_URL/brand/... through Cloudinary, else local /brand.
NEXT_PUBLIC_CLOUDINARY_BRAND_LOGO_ID=""

# Google Maps (route preview on Vacation Feasibility Radar)
# Local testing: add your key to frontend/.env.local (gitignored — never commit keys).
# Production: set in hosting env (e.g. Vercel) using the client's GCP project key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=""

# Vercel production example:
# NEXT_PUBLIC_SITE_URL="https://www.browsemyvacations.com"
# NEXT_PUBLIC_API_URL="https://api.browsemyvacations.com/api/v1"
