# Backend API — copy to .env
# DATABASE_URL: use database/.env or set here for deployed API container

NODE_ENV=development
PORT=3101

# PostgreSQL (local docker-compose)
DATABASE_URL="postgresql://bmv:bmv@localhost:5434/browsemyvacations?schema=public"
DIRECT_URL="postgresql://bmv:bmv@localhost:5434/browsemyvacations?schema=public"

# Redis (local docker-compose) — for future BullMQ lead emails
REDIS_URL="redis://localhost:6379"

# CORS — comma-separated origins (frontend URLs)
CORS_ORIGIN="http://localhost:3100"

# Auth (admin — implement in Phase 1+)
JWT_SECRET="change-me-use-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# Email (Resend — lead notifications)
RESEND_API_KEY=""
OPS_EMAIL_TO="sales@browsemyvacations.com"
OPS_EMAIL_FROM="Browse My Vacations <noreply@browsemyvacations.com>"

# Rate limits (optional overrides)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Cloudinary (optional locally — dev uses ./uploads when unset)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
PUBLIC_API_BASE_URL="http://localhost:3101"

# Railway / Render production example:
# PORT=3101
# DATABASE_URL=<neon-pooled-url>
# DIRECT_URL=<neon-direct-url>
# REDIS_URL=<upstash-redis-url>
# CORS_ORIGIN="https://www.browsemyvacations.com,https://browsemyvacations.com"
